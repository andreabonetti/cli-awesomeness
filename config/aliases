# kill
#
# usage:
# $ kill_by_name process_name
kill_by_name() {
  local pids
  pids=$(pgrep "$1")

  if [[ -z "$pids" ]]; then
    echo "No process found matching the name \"$1\""
  else
    echo "$pids" | xargs kill -9
    echo "Killed processes with name \"$1\" and PID $pids"
  fi
}

# quarto
#
# usage:
# $ quarto_preview my_document.qmd
# $ quarto_render_pdf my_document.qmd
# $ quarto_render_docx my_document.qmd
quarto_preview() {
  quarto preview "$1"
}
quarto_render_pdf() {
  quarto render "$1" --to pdf
}
quarto_render_docx() {
  quarto render "$1" --to docx
}
quarto_render_html() {
  quarto render "$1" --to html
}
# ...more aliases for export:
alias quarto_export_pdf='quarto_render_pdf'
alias quarto_export_docx='quarto_render_docx'
alias quarto_export_html='quarto_render_html'

